[terminal]
shell = { program = "C:/Program Files/Git/bin/bash.exe", args = [
    "--login",
    "-i",
] }

[window]
dynamic_title = true
decorations = "None"
startup_mode = "Maximized"
opacity = 1.0
padding = { x = 5, y = 5 }
dynamic_padding = true

[mouse]
hide_when_typing = true

[font]
size = 12.0
[font.normal]
family = "MesloLGM Nerd Font"

[general]
working_directory = "{{ .chezmoi.homeDir }}/dev"
import = ["~/.config/alacritty/themes/themes/gruvbox_dark.toml"]

[cursor]
style = { shape = "Beam", blinking = "Off" }

[keyboard]
bindings = [
    { key = 'PageUp', mods = "Shift", action = 'ScrollPageUp' },
    { key = 'PageDown', mods = "Shift", action = 'ScrollPageDown' },
    { key = 'PageUp', mods = "Control", action = 'ScrollToTop' },
    { key = 'PageDown', mods = "Control", action = 'ScrollToBottom' },
    # Forward Alt+Enter to pi as ESC+CR (legacy alt encoding) for app.message.followUp.
    # Overrides Alacritty's default ToggleFullscreen on this combo.
    { key = "Return", mods = "Alt", chars = "\r" },
    # Layout-independent Paste/Copy via scancode (Windows: V=47, C=46).
    # Disable default keysym bindings to avoid double-fire on EN layout.
    { key = "V", mods = "Control|Shift", action = "None" },
    { key = "C", mods = "Control|Shift", action = "None" },
    { key = 47, mods = "Control|Shift", action = "Paste" },
    { key = 46, mods = "Control|Shift", action = "Copy" },
]
