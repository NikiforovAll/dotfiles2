# Fix: non-WT terminals (Alacritty from Start Menu, PowerToys Run) inherit only Machine PATH.
# winget installs shims to User PATH, so add its Links dir explicitly. Must run before .bashrc (fzf/zoxide).
if [[ -z "$WT_SESSION" ]]; then
    extra="$LOCALAPPDATA/Microsoft/WinGet/Links"
    for d in "$LOCALAPPDATA"/Microsoft/WinGet/Packages/{ajeetdsouza.zoxide,junegunn.fzf}_*/; do
        [[ -d "$d" ]] && extra="$extra:${d%/}"
    done
    export PATH="$PATH:$extra"
fi

if [ -f ~/.bashrc ]; then
    source ~/.bashrc
fi

export dev="$HOME/dev"