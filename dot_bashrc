eval "$(fzf --bash)"

_fzf_history_dedup() {
    builtin history -a
    builtin history -c
    builtin history -r
    READLINE_LINE=$(
        HISTTIMEFORMAT='' builtin history |
        sed 's/^ *[0-9]* *//' |
        awk '!seen[$0]++' |
        fzf --tac --no-sort --scheme=history \
            --bind 'ctrl-y:execute-silent(echo -n {} | clip)+abort' \
            --color header:italic \
            --header 'Press CTRL-Y to copy command into clipboard' \
            --query "$READLINE_LINE"
    ) || true
    READLINE_POINT=${#READLINE_LINE}
}

bind -x '"\C-r": _fzf_history_dedup'

function fzfp() {
    local PROJECTS=$(dotnet sln list | sed '1,2d')
    echo "$PROJECTS" | fzf --preview "bat --style=numbers --color=always --line-range :500 {} -l xml"
}

# scratch pad picker — fzf-select a pad under $PWD (or arg root), open in viewer.
# Passes the pad NAME (not a path) back to scratch, which resolves it internally —
# keeps Windows paths out of the shell round-trip.
alias sch='scratch'

sui() {
    local root="${1:-$PWD}" names name
    # Drain the native producers (bun/scratch, jq) FULLY before launching fzf.
    # Piping Windows-native procs straight into fzf on Git Bash leaks a console
    # handle down the chain and fzf can't own the tty for keyboard input. Feeding
    # fzf from the printf builtin (after the procs have exited) is the clean case.
    names=$(scratch ls --dir "$root" --json | jq -r '.pads | sort_by(.updated) | reverse | .[].name' | tr -d '\r')
    [[ -z "$names" ]] && return 0
    # fzf previews are lazy: the preview runs only for the focused item and is
    # cached per item. Spawning scratch (bun) here is fine — preview stdout is
    # captured by fzf and never touches the keyboard tty that nav depends on.
    name=$(printf '%s\n' "$names" \
           | fzf --reverse --prompt 'pad> ' \
                 --preview "scratch ls {} --dir '$root'" \
                 --preview-window 'right,55%') || return 0
    scratch ui "$name" --dir "$root"
}
# fzf for searching file contents with rg, preview with bat, and copy path:line to clipboard with ctrl-y
rfzf() {
    fzf --disabled --ansi --query "$*" \
        --height 90% \
        --layout reverse \
        --preview-window 'down,80%,border-top,+{2}-5' \
        --delimiter : \
        --bind "start:reload:rg --column --line-number --no-heading --color=always --smart-case -- {q} || true" \
        --bind "change:reload:rg --column --line-number --no-heading --color=always --smart-case -- {q} || true" \
        --preview 'bat --style=numbers --color=always --highlight-line {2} {1}' \
        --bind 'ctrl-/:change-preview-window(right,60%|down,80%|hidden)' \
        --bind "ctrl-y:execute-silent(echo -n {1}:{2} | clip)" \
    | cut -d: -f1
}

cwt() {
  local selection=$(git worktree list | fzf \
    --header "ENTER=cd | CTRL-Y=copy path | CTRL-D=remove worktree" \
    --bind "ctrl-y:execute-silent(echo -n {1} | clip)+abort" \
    --bind "ctrl-d:execute(git worktree remove {1})+reload(git worktree list)" \
    --no-mouse)
  local dir=$(echo "$selection" | awk '{print $1}')
  [[ -n "$dir" ]] && cd "$dir"
}

