######
# prompt
######
__git_branch() {
    local head gitdir=".git"
    [[ -e "$gitdir" ]] || return
    # Support submodules where .git is a file pointing to the real gitdir
    if [[ -f "$gitdir" ]]; then
        read -r _ gitdir < "$gitdir"
    fi
    read -r head < "$gitdir/HEAD" 2>/dev/null || return
    case "$head" in
        ref:*) printf ' \e[38;2;255;255;255mon\e[0m \e[38;2;255;148;223m\ue0a0 %s\e[0m' "${head#ref: refs/heads/}" ;;
        *) printf ' \e[38;2;255;255;255mon\e[0m \e[38;2;255;148;223m\ue0a0 %s\e[0m' "${head:0:7}" ;;
    esac
}
PROMPT_COMMAND='PS1="\[\e[36m\]\W\[\e[0m\]$(__git_branch)\n\[\e[92m\]❯\[\e[0m\] ";'"${PROMPT_COMMAND}"

