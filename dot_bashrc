# azt — switch Azure CLI between profiles via isolated config dirs (convention-based).
# Convention: profile <name> lives in ~/.azure-<name>; 'home' (or no arg) = default ~/.azure.
# Each profile keeps its own token cache + active subscription (no cross-contamination).
# Create a new profile just by switching to it and logging in — nothing to hardcode:
#   azt work && az login --use-device-code [--allow-no-subscriptions]
# Usage:
#   azt          -> show current profile
#   azt ls       -> list existing profiles
#   azt home     -> default ~/.azure (current EPAM login)
#   azt <name>   -> switch to ~/.azure-<name> (creates on first login)
azt() {
  case "$1" in
    "")
      local cur="${AZURE_CONFIG_DIR##*/.azure-}"
      [ -z "$AZURE_CONFIG_DIR" ] && cur="home"
      echo "active: $cur  (${AZURE_CONFIG_DIR:-$HOME/.azure})"; return ;;
    ls)
      echo "home  ($HOME/.azure)"
      for d in "$HOME"/.azure-*/; do
        [ -d "$d" ] && echo "${d%/}" | sed "s|$HOME/.azure-|  |"
      done; return ;;
    home) unset AZURE_CONFIG_DIR ;;
    *)    export AZURE_CONFIG_DIR="$HOME/.azure-$1" ;;
  esac
  echo "profile -> ${1:-home}  (${AZURE_CONFIG_DIR:-$HOME/.azure})"
  az account show --query '{tenant:tenantId, user:user.name, sub:name}' -o table 2>/dev/null \
    || echo "(not logged in here yet -> run: az login --use-device-code --allow-no-subscriptions)"
}
