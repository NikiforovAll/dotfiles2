# tmux
######

# Usage: t [-n name] [folder] - attach/create tmux session named after folder (default: current dir)
t() {
  local name_override=""
  local OPTIND=1
  while getopts "n:" opt; do
    case $opt in
      n) name_override="$OPTARG" ;;
    esac
  done
  shift $((OPTIND - 1))

  local target_dir="${1:-$PWD}"
  local session_name="${name_override:-$(basename "$target_dir" | tr . _)}"

  if tmux has-session -t "=$session_name" 2>/dev/null; then
    if [ -n "$TMUX" ]; then
      tmux switch-client -t "=$session_name"
    else
      tmux attach-session -t "=$session_name"
    fi
  else
    if [ -n "$TMUX" ]; then
      tmux new-session -d -s "$session_name" -c "$target_dir"
      tmux switch-client -t "=$session_name"
    else
      tmux new-session -s "$session_name" -c "$target_dir"
    fi
  fi
}

# Tmux Dev Session Picker - fzf select from ~/dev, attach/create session
tdev() {
  local dir
  dir=$(fd . ~/dev -d 1 -t d | sed 's|C:/|/c/|i;s|/$||' | fzf --reverse)
  [[ -z "$dir" ]] && return 0
  t "$dir"
}

# Usage: tw [-n name] [folder] - create new tmux window named after folder (default: current dir)
tw() {
  local name_override=""
  local OPTIND=1
  while getopts "n:" opt; do
    case $opt in
      n) name_override="$OPTARG" ;;
    esac
  done
  shift $((OPTIND - 1))

  local target_dir="${1:-$PWD}"
  local window_name="${name_override:-$(basename "$target_dir" | tr . _)}"

  if [ -z "$TMUX" ]; then
    echo "Not in a tmux session"
    return 1
  fi

  tmux new-window -n "$window_name" -c "$target_dir"
}

